#!/bin/bash
# ============================================================
# UTILIDADES PERSONALIZADAS PARA TERMINAL
# Autor: Carlos Eduardo Ocando Azuaje
# Descripción:
#   - Variables globales para despliegue GlassFish
#   - Función avanzada de búsqueda de archivos
#   - Soporte para filtrado interactivo
#   - Exportación automática de resultados
# ============================================================

# ============================================================
# CONSTANTES GLOBALES
# ============================================================

# Ruta base del proyecto
FUENTES="/Users/carlosocando/Documentos/referidos_elias/1.0-war"

# Carpeta target generada por Maven
TARGET="$FUENTES/target"

# Nombre del proyecto sin extensión
PROYECTO_SIN_EXTENSION="referidosrrvv-1.0"

# Extensión WAR
EXTENSION_WAR="war"

# Nombre completo del WAR
WAR="${PROYECTO_SIN_EXTENSION}.${EXTENSION_WAR}"

# Ruta final del WAR
WAR_PATH="$TARGET/$WAR"

# Ruta del ejecutable asadmin
ASADMIN="/Users/carlosocando/Downloads/glassfish7/glassfish8/glassfish/bin/asadmin"

# URL administrativa de GlassFish
GLASSFISH_ADMIN_URL="http://localhost:4848/common/applications/applications.jsf"

# Mensaje estándar para pausas
ENTER="**** Presione ENTER para continuar ..."

# Directorio home
USERS="$HOME"

# Colores
RED="\033[1;31m"
RESET="\033[0m"

# ============================================================
# FUNCIÓN: XREQUIRE
# Descripción:
#   - Verifica que un comando exista en el sistema
# ============================================================
function xrequire() {

	# Validar parámetro
	if [ -z "$1" ]; then
		echo "❌ Uso: xrequire <comando>"
		return 1
	fi

	# Verificar existencia
	if ! command -v "$1" >/dev/null 2>&1; then
		echo "❌ Dependencia faltante: $1"
		return 1
	fi
}

# ============================================================
# FUNCIÓN: XFIND
# Descripción:
#   - Busca archivos desde el directorio actual
#   - Permite filtrado opcional
#   - Si no recibe filtro, lo solicita
#   - Guarda resultados en /tmp/xfind.txt
#   - Abre resultados en Sublime Text
#
# Uso:
#   xfind <nombre_archivo> [texto_filtro]
# ============================================================
function xfind() {

	local archivos
	local filtro="$2"

	# Validar parámetro principal
	if [ -z "$1" ]; then
		echo "❌ Uso: xfind <archivo> [texto_a_filtrar]"
		echo "📌 Ejemplo:"
		echo '   xfind "*.jar" crypto'
		return 1
	fi

	# Solicitar filtro si no fue proporcionado
	if [ -z "$filtro" ]; then
		read "filtro?**** Ingrese texto para filtrar resultados (Enter para omitir): "
	fi

	echo "**** Buscando ..."

	# Buscar archivos con o sin filtro
	if [ -n "$filtro" ]; then
		archivos=$(sudo find . -type f -name "$1" 2>/dev/null | grep -i --color=always -F "$filtro")
	else
		archivos=$(sudo find . -type f -name "$1" 2>/dev/null)
	fi

	# Guardar resultados
	echo "$archivos" >/tmp/xfind.txt

	# Mostrar resultados
	echo -e -e "\n**** Resultados encontrados:"
	echo "$archivos"

	# Información adicional
	echo -e -e "\n**** cmd + ctrl + G / (Busca: $1)"

	if [ -n "$filtro" ]; then
		echo "**** Filtro aplicado: $filtro"
	fi

	echo "**** Archivos encontrados: $(echo "$archivos" | grep -c .)"

	# Abrir resultados en Sublime Text
	subl /tmp/xfind.txt
}

