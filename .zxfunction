# ============================================================
# FUNCIÓN: xclose
# DESCRIPCIÓN:
# Cierra una aplicación por nombre (proceso)
#
# USO:
#   xclose nombre_app
# ============================================================

function xclose {

	# Validación: debe venir el nombre del proceso
	if [ -z "$1" ]; then
		echo "Uso: xclose nombre_app"
		echo ""
		echo "Ejemplos:"
		echo "  xclose code"
		echo "  xclose java"
		echo "  xclose chrome"
		return 1
	fi

	local app="$1"

	echo "🔎 Buscando procesos de: $app"

	# Obtener PIDs
	local pids=$(pgrep -f "$app")

	if [ -z "$pids" ]; then
		echo "⚠️ No se encontraron procesos para: $app"
		return 1
	fi
	echo "**** Proceso terminado ... "

}

# ============================================================
# FUNCIÓN: XGITALL
# Autor: Carlos Eduardo Ocando Azuaje
# Descripción:
#   - Agrega todos los cambios al repositorio Git
#   - Realiza commit con el mensaje recibido
#   - Ejecuta push al repositorio remoto
#   - Muestra estado final del repositorio
#   - Muestra último commit realizado
#   - Muestra rama actual y seguimiento remoto
#
# Uso:
#   xgitall "mensaje del commit"
#
# Ejemplo:
#   xgitall "actualización de funciones bash"
# ============================================================

function xgitall {

	# ============================================================
	# SELECCIÓN DE RESPALDO (y/n)
	# ============================================================
	# echo "===================================================="
	xzen entry "'y' para Google Drive? o 'n' para Git (y/n)"
	# echo "===================================================="

	# read "RESPALDO?Ingrese opción [y/n]: "

	# xzen entry "Quiere enviar Drive, Ingrese opción [y/n]"

	# Normalizar entrada
	xval=$(echo "$xval" | tr '[:upper:]' '[:lower:]')

	# ============================================================
	# CONSTANTES
	# ============================================================
	# ============================================================
	# RESPALDO MÚLTIPLE A GOOGLE DRIVE
	# ============================================================

	if [ "$xval" = "n" ]; then
		# echo -e "\nEjecutando respaldo para Git ...\n"
		xzen info "Ejecutando respaldo para Git ...\n"

		# source cd ~/para_git

		# --------------------------------------------------------
		# Agregar todos los cambios al staging
		# --------------------------------------------------------
		git add ~/.zxalias ~/.zxfunction ~/.zshrc

		# --------------------------------------------------------
		# Crear commit con mensaje
		# --------------------------------------------------------
		git commit -m "${1:-Actualización ...}"

		# --------------------------------------------------------
		# Subir cambios al remoto
		# --------------------------------------------------------
		git push

		# --------------------------------------------------------
		# Mostrar estado actual
		# --------------------------------------------------------
		git status

		# --------------------------------------------------------
		# Mostrar último commit
		# --------------------------------------------------------
		git log -1 &&

			# --------------------------------------------------------
			# Mostrar rama actual con tracking
			# --------------------------------------------------------
			# echo -e "\n**** Información de ramas ...."
			# xzen info "**** Información de ramas ...."
			# echo "==============================================================="
			xzen info "**** Rama actual: $(git branch --show-current)"
		# echo -e "===========================================================\n"

		xzen info "**** Proceso de git completo ..."

		open https://github.com/

		xpausa 5

	else

		REMOTO="gdrive"
		# CARPETA_REMOTA="/Users/carlosocando/para_git/*"
		CARPETA_REMOTA="/z"

		ARCHIVO_LOCAL1="$HOME/.zxfunction"
		ARCHIVO_LOCAL2="$HOME/.zxalias"
		ARCHIVO_LOCAL3="$HOME/.zshrc"
		ARCHIVO_LOCAL4="/Users/carlosocando/de_todo/Sustituciones de texto.plist"
		# CARPETA_REMOTA="/Users/carlosocando/para_git"
		# ARCHIVO_LOCAL6="/private/tmp/deploy/deploy.sh"
		# ARCHIVO_LOCAL6="/private/tmp/deploy/find.sh"
		# ARCHIVO_LOCAL6="/private/tmp/deploy/url.sh"

		# ------------------------------------------------------------
		# LISTA DE ARCHIVOS
		# ------------------------------------------------------------
		ARCHIVOS=(
			"$ARCHIVO_LOCAL1"
			"$ARCHIVO_LOCAL2"
			"$ARCHIVO_LOCAL3"
			"$ARCHIVO_LOCAL4"
			# "$ARCHIVO_LOCAL5"
			# "$CARPETA_REMOTA"
		)

		# ------------------------------------------------------------
		# RECORRER Y SUBIR CADA ARCHIVO
		# ------------------------------------------------------------
		# for ARCHIVO in "${ARCHIVOS[@]}"; do

		# Validar existencia
		if [[ ! -f "$ARCHIVO" ]]; then
			# echo "❌ No existe: $ARCHIVO"
			xzen error "❌ No existe: $ARCHIVO"
			continue
		fi

		# echo "==========================================================="
		xzen info "📤 **** Subiendo: $ARCHIVO"
		# echo "==========================================================="

		# rclone copy "$HOME" "$REMOTO:$ARCHIVO" \
		# --progress \
		# --exclude "**/node_modules/**" \
		# --exclude "**/.git/**" \
		# --exclude "**/Library/Caches/**" \
		# --exclude ".Trash-*/**" \
		# --exclude ".Trashes/**" \
		# --exclude "Trash/**" \
		# --exclude ".Trash/**"

		xzen info "📤 **** Subiendo: $ARCHIVO_LOCAL1"
		rclone copy "$HOME" "$REMOTO":"$ARCHIVO_LOCAL1" 2>/dev/null

		xzen info "📤 **** Subiendo: $ARCHIVO_LOCAL2"
		rclone copy "$HOME" "$REMOTO":"$ARCHIVO_LOCAL2" 2>/dev/null

		xzen info "📤 **** Subiendo: $ARCHIVO_LOCAL3"
		rclone copy "$HOME" "$REMOTO":"$ARCHIVO_LOCAL3" 2>/dev/null

		xzen info "📤 **** Subiendo: $ARCHIVO_LOCAL4"
		rclone copy "$HOME" "$REMOTO":"$ARCHIVO_LOCAL4" 2>/dev/null

		xpausa 5

		# Validar resultado
		if [[ $? -eq 0 ]]; then
			xzen info "✅ Subida completada: $ARCHIVO"
		else
			xzen error "❌ Error al subir: $ARCHIVO"
		fi
		xzen info "Conectar con la pagina de Google Drive para verificar el respaldo ..."
		xpausa 10

		# done

		open https://drive.google.com/drive/u/1/my-drive

		xpausa 10

	fi
	# xzen info "============================================================="
	xzen info "🚀 **** Respaldo finalizado."
	# xzen info "============================================================="

}

