	xkeepz

}

# ____________________________________________________________
# GLASSFISH BUILD + DEPLOY
# FUNCIONES DE LIMPIEZA, COMPILACIÓN Y DESPLIEGUE
# Autor: Carlos Eduardo Ocando Azuaje
# Descripción:
#   - Limpia caché de Brave Browser
#   - Compila proyecto Maven
#   - Realiza deploy forzado en GlassFish
#   - Abre panel administrativo
# ____________________________________________________________

# ------------------------------------------------------------
# XXLSGLAS
# Descripción:
#   - Borra caché de Brave
#   - Ejecuta mvn clean package
#   - Despliega WAR indicado
#   - Abre consola GlassFish
#
# Uso:
#   xxlsglas archivo.war
# ------------------------------------------------------------
function xxlsglas {

	# Limpiar caché principal de Brave
	rm -rf ~/Library/Caches/BraveSoftware/Brave-Browser/*

	# Limpiar caché de perfil por defecto
	rm -rf ~/Library/Application\ Support/BraveSoftware/Brave-Browser/Default/Cache/*

	# Compilar proyecto y desplegar
	mvn clean package &&
		/Users/carlosocando/Downloads/glassfish7/glassfish/domains/domain1/bin/asadmin deploy --force target/"$1" &&
		open http://www.localhost:4848/common/index.jsf
}

# ____________________________________________________________
# NAVEGACIÓN
# ACCESO RÁPIDO A DIRECTORIOS
# ____________________________________________________________

# ------------------------------------------------------------
# XCD
# Descripción:
#   - Cambia de directorio usando pushd
#   - Lista contenido
#   - Muestra ruta actual
#
# Uso:
#   xcd ruta
# ------------------------------------------------------------
function cd {

	# Cambiar directorio y guardar historial
	pushd "$1"

	# Listar contenido
	ll

	# Mostrar ubicación actual
	pwd
}

# ============================================================
# FUNCIÓN: xdif
# DESCRIPCIÓN:
#   Compara dos archivos usando diff en formato unified (-u),
#   guarda el resultado en /tmp/xdif.txt y lo abre con Sublime Text.
#
# USO:
#   xdif archivo1 archivo2
#
# EJEMPLO:
#   xdif cp_remote.sh cp_remoto.sh
# ============================================================

function xdif {

	# Validar cantidad de parámetros
	if [ $# -ne 2 ]; then
		echo "Uso: xdif <archivo1> <archivo2>"
		echo "Ejemplo: xdif cp_remote.sh cp_remoto.sh"
		return 1
	fi

	# Variables
	local ARCHIVO1="$1"
	local ARCHIVO2="$2"
	local SALIDA="/tmp/xdif.txt"

	# Validar existencia
	if [ ! -f "$ARCHIVO1" ]; then
		echo "Error: No existe '$ARCHIVO1'"
		return 1
	fi

	if [ ! -f "$ARCHIVO2" ]; then
		echo "Error: No existe '$ARCHIVO2'"
		return 1
	fi

	# Ejecutar diff
	diff -u "$ARCHIVO1" "$ARCHIVO2" >"$SALIDA"

	# Confirmar resultado
	echo "Diff guardado en: $SALIDA"

	# Abrir en Sublime Text
	subl "$SALIDA"
}

