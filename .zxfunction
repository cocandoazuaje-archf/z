# ____________________________________________________________
# FD / GREP
# FUNCIONES DE BÚSQUEDA RÁPIDA Y FILTRADO
# Autor: Carlos Eduardo Ocando Azuaje
# Descripción:
#   - xfd2: búsqueda recursiva con grep usando dos patrones
#   - xfd : búsqueda rápida de archivos con fd
# ____________________________________________________________

# ------------------------------------------------------------
# XFD2
# Descripción:
#   - Busca recursivamente contenido usando grep
#   - Soporta dos patrones combinados con OR
#   - Exporta resultados a /tmp/xfd2.txt
#   - Abre resultados en Sublime Text
#
# Uso:
#   xfd2 <patron1> <patron2>
# ------------------------------------------------------------
function xfd2 {
	echo "**** Procesando ..."

	# Validar cantidad mínima de parámetros
	if [ $# -lt 2 ]; then
		echo "Uso: xfd2 <patron1> <patron2>"
		return 1
	fi

	# Buscar coincidencias recursivamente
	grep -R -i -E "$1|$2" . >/tmp/xfd2.txt

	# Abrir resultados
	subl /tmp/xfd2.txt
}

# ------------------------------------------------------------
# XFD
# Descripción:
#   - Busca archivos usando fd
#   - Incluye archivos ocultos
#   - Búsqueda insensible a mayúsculas
#   - Exporta resultados a /tmp/xfd.txt
#   - Abre resultados en Sublime Text
#
# Uso:
#   xfd <patron>
# ------------------------------------------------------------
function xfd {
	echo "**** Procesando ..."

	# Verificar disponibilidad del comando fd
	fd -H || return 1

	# Validar parámetro obligatorio
	if [ $# -eq 0 ]; then
		echo "Uso: xfd <patron>"
		return 1
	fi

	# Ejecutar búsqueda
	fd -i "$1" >/tmp/xfd.txt

	# Abrir resultados
	subl /tmp/xfd.txt
}

# ____________________________________________________________
# FINDER
# APERTURA RÁPIDA DE DIRECTORIOS EN FINDER
# ____________________________________________________________

# ------------------------------------------------------------
# XFINDER
# Descripción:
#   - Abre una ruta en Finder
#   - Si no recibe parámetro, abre directorio actual
#
# Uso:
#   xfinder [ruta]
# ------------------------------------------------------------
function xfinder {
	echo "**** Procesando ..."

	# Usar ruta actual si no se especifica
	RUTA="${1:-$PWD}"

	# Validar existencia del directorio
	if [ ! -d "$RUTA" ]; then
		echo "❌ Ruta no válida: $RUTA"
		return 1
	fi

	# Abrir en Finder
	open "$RUTA"
}

# ____________________________________________________________
# LISTADO
# FUNCIONES DE VISUALIZACIÓN DE ARCHIVOS
# ____________________________________________________________

# ------------------------------------------------------------
# XLL
# Descripción:
#   - Lista archivos ordenados por tamaño
#   - Incluye archivos ocultos
#   - Muestra permisos detallados
#   - Muestra ruta actual
#
# Uso:
#   xll [ruta]
# ------------------------------------------------------------
function xll() {

	# Listado detallado ordenado por tamaño
	command ls -lahSr "${1:-.}"

	# Mostrar directorio actual
	builtin pwd
}

# ------------------------------------------------------------
# LL
# Descripción:
#   - Alias funcional para xll
# ------------------------------------------------------------
function ll {
	xll "$1"
}

# ____________________________________________________________
# RED
# FUNCIONES DE MONITOREO DE RED
# Autor: Carlos Eduardo Ocando Azuaje
# Descripción:
#   - Muestra IP pública, IP local y gateway
#   - Refresco automático cada 5 segundos
# ____________________________________________________________
function xip {

	# Bucle infinito de monitoreo
	while true; do
		clear

		# Encabezado
		echo "**** Informacion sobre ips"

		# Mostrar IP pública
		echo -e "\033[1;32mPublica:\033[0m $(curl -s ifconfig.me)"

		# Mostrar IP local
		echo -e "\033[1;34mLocal:\033[0m $(ipconfig getifaddr en0)"

		# Mostrar gateway por defecto
		echo -e "\033[1;31mGateway:\033[0m $(route -n get default | awk '/gateway/ {print $2}')"

		# Esperar antes de refrescar
		sleep 5
	done
}

# ____________________________________________________________
# HISTORIAL
# CONSULTA DE HISTORIAL DE COMANDOS
# ____________________________________________________________
function xchis {

	# Mostrar historial completo si no hay filtro
	if [ -z "$1" ]; then
		history
	else

		# Filtrar historial por patrón
		history | grep -i --color=auto "$1"
	fi
}

# ____________________________________________________________
# PERMISOS
# ASIGNAR PERMISOS DE EJECUCIÓN
# ____________________________________________________________
function xchx {

	# Validar parámetro obligatorio
	[[ -z "$1" ]] && echo "Uso: xchx <archivo>" && return 1

	# Validar existencia del archivo
	[[ ! -f "$1" ]] && echo "No existe: $1" && return 1

	# Asignar permisos ejecutables
	chmod +x "$1"

	# Mostrar información final
	ls -lah "$1"
	pwd
}

# ____________________________________________________________
# LOGS
# CONSULTA Y FILTRADO DE LOGS
# ____________________________________________________________
function xlogs {

	# Parámetros
	LOGFILE="$1"
	PATTERN="$2"

	# Validar archivo
	if [[ ! -f "$LOGFILE" ]]; then
		echo "Archivo no encontrado: $LOGFILE"
		return 1
	fi

	# Mostrar últimas líneas si no hay filtro
	if [[ -z "$PATTERN" ]]; then
		tail -n 50 "$LOGFILE"
	else

		# Filtrar contenido
		grep -i --color=always "$PATTERN" "$LOGFILE" | less -R
	fi
}

# ____________________________________________________________
# BRAVE
# APERTURA RÁPIDA DE URL EN BRAVE BROWSER
# ____________________________________________________________
function xbrave {

	# Validar URL
	if [ -z "$1" ]; then
		echo "Uso: xbrave <url>"
		return 1
	fi

	local url="$1"

	# Agregar protocolo si falta
	[[ ! "$url" =~ ^https?:// ]] && url="https://$url"

	# Abrir solo en macOS
	if [[ "$OSTYPE" == "darwin"* ]]; then
		open -a "Brave Browser" "$url"
	else
		echo "No soportado en este sistema"
	fi
}

# ____________________________________________________________
# GLASSFISH
# CONTROL DE DOMINIO GLASSFISH
# ____________________________________________________________

# ------------------------------------------------------------
# XGLASON
# Descripción:
#   - Inicia dominio GlassFish
# ------------------------------------------------------------
function xglason {

	ASADMIN="/Users/carlosocando/Downloads/glassfish7/glassfish8/glassfish/bin/asadmin"

	# Iniciar dominio si recibe parámetro 1
	if [ "$1" == "1" ]; then
		sh "$ASADMIN" start-domain
	fi
}

# ------------------------------------------------------------
# XGLASOFF
# Descripción:
#   - Detiene dominio GlassFish
# ------------------------------------------------------------
function xglasoff {

	ASADMIN="/Users/carlonsocando/Downloads/glassfish7/glassfish8/glassfish/bin/asadmin"

	# Detener dominio si no recibe parámetros
	if [ -z "$1" ]; then
		sh "$ASADMIN" stop-domain
	fi
}

# ____________________________________________________________
# GIT
# RESPALDO COMPLETO DE CAMBIOS
# ____________________________________________________________
function xgit_all {

	# Agregar cambios, commit y push
	git add . && git commit -m "$1" && git push
}

# ____________________________________________________________
# TAR
# COMPRESIÓN DE ARCHIVOS Y DIRECTORIOS
# ____________________________________________________________
function xtar {

	# Ruta origen
	ORIGEN="$1"

	# Nombre del archivo comprimido
	DESTINO="${1}.tar.gz"

	# Validar parámetro obligatorio
	if [ -z "$ORIGEN" ]; then
		echo "Uso: xtar <archivo|carpeta>"
		return 1
	fi

	# Crear archivo tar.gz
	tar -czvf "$DESTINO" "$ORIGEN"

	# Validar resultado
	if [ $? -eq 0 ]; then
		echo "✔ Creado: $DESTINO"
	else
		echo "❌ Error al crear"
	fi
}

# ____________________________________________________________
# NAVEGACIÓN DE PROYECTO
# FUNCIONES DE ACCESO RÁPIDO AL PROYECTO WAR
# Autor: Carlos Eduardo Ocando Azuaje
# Descripción:
#   - Cambian al directorio del proyecto
#   - Listan contenido
#   - Muestran ruta actual
# ____________________________________________________________

# ------------------------------------------------------------
# XCD_GIT
# Descripción:
#   - Accede al directorio principal del proyecto
# ------------------------------------------------------------
function xcd_git {

	# Cambiar al directorio del proyecto
	cd "$WAR_1_0" || return 1

	# Mostrar contenido
	ls -ha

	# Mostrar ubicación actual
	pwd
}

# ------------------------------------------------------------
# GO_PROJECT
# Descripción:
#   - Pausa informativa
#   - Accede al proyecto
# ------------------------------------------------------------
function go_project {

	# Mostrar mensaje interactivo
	echo -e "$ENTER hacer cd ... \n" </dev/tty

	# Cambiar directorio
	cd "$WAR_1_0" || return 1

	# Mostrar contenido
	ls -ha

	# Mostrar ruta
	pwd
}

# ____________________________________________________________
# BUILD
# COMPILACIÓN DEL PROYECTO
# ____________________________________________________________

# ------------------------------------------------------------
# BUILD_PROJECT
# Descripción:
#   - Ejecuta Maven clean package con debug
# ------------------------------------------------------------
function build_project {

	# Mensaje previo
	echo -e "$ENTER package ... \n" </dev/tty

	# Compilar proyecto
	mvn clean package -X
}

# ____________________________________________________________
# GLASSFISH DEPLOYMENT
# FUNCIONES DE DESPLIEGUE
# ____________________________________________________________

# ------------------------------------------------------------
# UNDEPLOY_PROJECT
# Descripción:
#   - Elimina despliegue actual de GlassFish
# ------------------------------------------------------------
function undeploy_project {

	# Mensaje previo
	echo -e "$ENTER undeploy ... \n" </dev/tty

	# Ejecutar undeploy
	"$ASADMIN" undeploy "$PROJECTO_SIN_EXTENCION"
}

# ------------------------------------------------------------
# DEPLOY_PROJECT
# Descripción:
#   - Realiza despliegue del proyecto en GlassFish
#   - Fuerza redeploy del WAR generado
# ------------------------------------------------------------
function deploy_project {

	# Primer intento de deploy por nombre
	echo -e "$ENTER deploy ... \n" </dev/tty
	"$ASADMIN" deploy "$PROJECTO_SIN_EXTENCION"

	# Deploy forzado desde WAR
	echo -e "$ENTER deploy ... \n" </dev/tty
	"$ASADMIN" deploy \
		--force=true \
		"$TARGET/$PROJECTO_SIN_EXTENCION.$EXTENCION_WAR"
}

# ------------------------------------------------------------
# REMOVE_WAR
# Descripción:
#   - Elimina archivo WAR generado
# ------------------------------------------------------------
function remove_war {

	# Mensaje previo
	echo -e "$ENTER rm ... \n" </dev/tty

	# Eliminar WAR
	rm "$TARGET/$PROJECTO_SIN_EXTENCION.$EXTENCION_WAR"
}

# ____________________________________________________________
# SUBIDA COMPLETA
# FLUJO AUTOMATIZADO DE BUILD + DEPLOY
# ____________________________________________________________

# ------------------------------------------------------------
# XSUBIR
# Descripción:
#   - Reinicia GlassFish
#   - Compila proyecto
#   - Undeploy
#   - Deploy
#   - Abre panel administrativo
# ------------------------------------------------------------
function xsubir {

	# Reiniciar GlassFish
	xglasoff
	xglason

	# Ir al proyecto
	go_project

	# Abrir carpeta target
	open "$TARGET"

	# Compilar
	build_project

	# Eliminar despliegue previo
	undeploy_project

	# Abrir consola GlassFish
	open "$GLAS"

	# Nuevo despliegue
	deploy_project

	# Abrir consola nuevamente
	open "$GLAS"
}

# ____________________________________________________________
# PAUSA
# CONTROL DE ESPERA
# ____________________________________________________________

# ------------------------------------------------------------
# XPAUSA
# Descripción:
#   - Pausa ejecución por segundos
# ------------------------------------------------------------
function xpausa {
	# Validar parámetro
	if [[ -z "$1" ]]; then
		echo "Uso: echo <segundos>"
		return 1
	fi

	# Validar entero
	if ! [[ "$1" =~ ^[0-9]+$ ]]; then
		echo "Error: debes pasar un número entero"
		return 1
	fi

	# Ejecutar pausa
	echo "⏸ Pausando $1 segundo(s)..."
	sleep "$1"
}

# Autor: Carlos Ocando
# Descripción:
#   Búsqueda avanzada tipo grep para proyectos grandes.
#   - Recursiva
#   - Case-insensitive por defecto
#   - Muestra archivo + línea + contenido
#   - Excluye node_modules y .git
# ============================================================

function xgrepgpt {

	# ------------------------------------------------------------
	# Validación de parámetro
	# ------------------------------------------------------------
	if [[ -z "$1" ]]; then
		echo "Uso: xgrepgpt <texto>"
		return 1
	fi

	# ------------------------------------------------------------
	# Variables
	# ------------------------------------------------------------
	SEARCH="$1"

	echo "======================================"
	echo "🔎 **** Buscando: $SEARCH"
	echo "======================================"

	# ------------------------------------------------------------
	# Búsqueda
	# ------------------------------------------------------------
	sudo grep -rin --color=always \
		--binary-files=without-match \
		--exclude-dir=node_modules \
		--exclude-dir=.git \
		"$SEARCH" .
}

# ____________________________________________________________
# GREP
# BÚSQUEDA RECURSIVA DE CONTENIDO
# ____________________________________________________________

# ------------------------------------------------------------
# XGREP
# Descripción:
#   - Busca texto recursivamente
#   - Exporta resultados
#   - Abre en Sublime Text
# ------------------------------------------------------------
function xgrep {

	echo "**** Procesando ..."

	# Buscar coincidencias
	sudo grep -Rni "$1" . 2>/dev/null >/tmp/xgrep.txt

	# Separador
	echo -e "\n-----------------------------------------------------------" >>/tmp/xgrep.txt

	# Listado de archivos
	ls >>/tmp/xgrep.txt

	# Separador
	echo "-------------------------------------------------------------" >>/tmp/xgrep.txt

	# Ruta actual
	pwd >>/tmp/xgrep.txt

	# Separador
	echo "-------------------------------------------------------------" >>/tmp/xgrep.txt

	# Finalización
	echo "**** Proceso finalizado ..." >>/tmp/xgrep.txt

	# Abrir resultados
	subl /tmp/xgrep.txt
}

# ------------------------------------------------------------
# XCOMPAREX
# Descripción:
#   - Solicita dos valores mediante Zenity
#   - Valida campos vacíos
#   - Muestra resultado gráfico
#
# Requiere:
#   - zenity instalado
# ------------------------------------------------------------
function xcompare {

	# Solicitar primer valor
	valor1=$(zenity --entry \
		--title="Comparación" \
		--text="Ingrese el primer valor:" 2>/dev/null) || return 1

	# Solicitar segundo valor
	valor2=$(zenity --entry \
		--title="Comparación" \
		--text="Ingrese el segundo valor:" 2>/dev/null) || return 1

	# Validar campos obligatorios
	if [ -z "$valor1" ] || [ -z "$valor2" ]; then

		# Advertencia por campos vacíos
		zenity --warning \
			--title="Error" \
			--text="No puedes dejar campos vacíos" 2>/dev/null

		return 1
	fi

	# Comparar resultados
	if [ "$valor1" = "$valor2" ]; then

		# Resultado positivo
		zenity --info \
			--title="Resultado" \
			--text="Son iguales" 2>/dev/null

	else

		# Resultado negativo
		zenity --error \
			--title="Resultado" \
			--text="Son diferentes" 2>/dev/null
	fi
}

# =========================================================
# Script: install_java.sh
# Descripción:
#   Instala OpenJDK vía brew, configura JAVA_HOME
#   y verifica la instalación.
#
# Uso:
#   ./install_java.sh <version>
#
# Ejemplo:
#   ./install_java.sh 17
# =========================================================

function xinsjav {

	# set -e

	# -------------------------
	# Validación de parámetros
	# -------------------------
	if [ -z "$1" ]; then
		echo "❌ Error: Debes indicar la versión de Java."
		echo ""
		echo "Uso:"
		echo "  ./install_java.sh <version>"
		echo ""
		echo "Ejemplo:"
		echo "  ./install_java.sh 17"
		echo ""
		echo "Esto instalará OpenJDK 17 y configurará JAVA_HOME."
		return 1
	fi

	JAVAVER="$1"

	echo "🔧 Instalando OpenJDK $JAVAVER ..."

	# -------------------------
	# Verificar brew
	# -------------------------
	if ! command -v brew >/dev/null 2>&1; then
		echo "❌ Homebrew no está instalado."
		echo "Instálalo desde: https://brew.sh"
		return 1
	fi

	# -------------------------
	# Instalar OpenJDK
	# -------------------------
	if [ "$2" = "r" ]; then
		echo "**** Re-instalando ..."
		brew reinstall openjdk@"$JAVAVER"
	else
		echo "**** Instalando ..."
		brew install openjdk@"$JAVAVER"
	fi

	# -------------------------
	# Configurar JAVA_HOME
	# -------------------------
	echo "⚙️ Configurando JAVA_HOME en ~/.zshrc ..."

	# Evitar duplicados
	if ! grep -q "java_home -v $JAVAVER" ~/.zshrc; then
		echo "" >>~/.zshrc
		echo "# Java $JAVAVER" >>~/.zshrc
		echo "export JAVA_HOME=\$(/usr/libexec/java_home -v $JAVAVER)" >>~/.zshrc
		echo 'export PATH=$JAVA_HOME/bin:$PATH' >>~/.zshrc
	fi

	# -------------------------
	# Aplicar cambios
	# -------------------------
	source ~/.zshrc

	# -------------------------
	# Verificación
	# -------------------------
	echo "✅ Java instalado:"
	java -version

	echo ""
	echo "🎯 JAVA_HOME actual:"
	echo "$JAVA_HOME"

}

# =========================================================
# FUNCIÓN: xcleanjava
# DESCRIPCIÓN:
#   Elimina versiones de OpenJDK instaladas vía Homebrew
#   y limpia completamente residuos del sistema.
#
# USO:
#   xcleanjava <version1> <version2>
#
# EJEMPLO:
#   xcleanjava 21 17
#
# NOTA:
#   - version1 se elimina forzado (--ignore-dependencies)
#   - version2 eliminación estándar
#   - elimina caches, binarios y restos manuales
# =========================================================
function xunsjav {

	# -------------------------
	# Validación de parámetros
	# -------------------------
	if [ -z "$1" ] || [ -z "$2" ]; then
		echo "❌ Debes indicar dos versiones de Java a eliminar."
		echo ""
		echo "Uso:"
		echo "  xcleanjava <version1> <version2>"
		echo ""
		echo "Ejemplo:"
		echo "  xcleanjava 21 17"
		echo ""
		echo "Esto eliminará:"
		echo "  - openjdk@<version1> (forzado)"
		echo "  - openjdk@<version2>"
		echo "  - caches y restos de instalación"
		return 0
	fi

	JDK1="$1"
	JDK2="$2"

	echo "🔍 JDKs instalados:"
	brew list | grep openjdk || true
	echo ""

	# -------------------------
	# Confirmación
	# -------------------------
	read "?⚠️ Esto eliminará versiones de Java. ¿Continuar? (y/N): " confirm
	if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
		echo "****❌Operación cancelada ..."
		return 0
	fi

	# -------------------------
	# Desinstalar JDKs
	# -------------------------
	echo "**** Eliminando openjdk@$JDK1 (forzado)..."
	brew uninstall --ignore-dependencies openjdk@"$JDK1" || true

	echo "🗑**** Eliminando openjdk@$JDK2 ..."
	brew uninstall openjdk@"$JDK2" || true

	echo "****🧹Limpieza de brew..."
	brew cleanup

	# -------------------------
	# Limpieza manual
	# -------------------------
	echo "🧹**** Eliminando restos ..."

	rm -rf ~/.java
	rm -rf ~/.jdk

	rm -rf /opt/homebrew/opt/openjdk*
	rm -rf /opt/homebrew/Cellar/openjdk*
	rm -rf /opt/homebrew/Cellar/openjdk@*

	rm -f /opt/homebrew/bin/java
	rm -f /opt/homebrew/bin/javac

	rm -rf ~/Library/Caches/Homebrew/downloads/*openjdk*

	echo "🧹**** Eliminando plugin antiguo (requiere sudo) ..."
	sudo rm -rf "/Library/Internet Plug-Ins/JavaAppletPlugin.plugin" 2>/dev/null || true

	sudo ln -sfn /opt/homebrew/opt/openjdk@"$1"/libexec/openjdk.jdk \
		/Library/Java/JavaVirtualMachines/openjdk-"$1".jdk

	java --version

	echo -e "\n-------------------------------------------------------------------------------------"
	echo "**** Limpieza completada. Verifica con 'java -version' y 'brew list | grep openjdk'. .."
}

# =========================================================
# FUNCIÓN: xunsglas
# DESCRIPCIÓN:
#   Elimina completamente instalaciones de GlassFish
#   ubicadas en el directorio home del usuario.
#
# USO:
#   xunsglas
#
# NOTA:
#   - Borra cualquier carpeta que coincida con ~/glassfish*
#   - Acción irreversible
#   - Requiere confirmación del usuario
# =========================================================

function xuniglas {

	echo "⚠️ Se eliminarán todas las carpetas ~/glassfish*"
	read "?¿Estás seguro? (y/N): " confirm

	if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
		echo "❌ Operación cancelada"
		return 0
	fi

	rm -rf ~/glassfish*

	echo "✅ GlassFish eliminado correctamente"
}

function xkkill {
	lsof -P | grep -i ':$1' | awk '{print $2}' | xargs kill -9
}

# =========================================================
# TÍTULO: xkill - Finalizar procesos por puerto
# DESCRIPCIÓN:
#   Mata todos los procesos que estén utilizando un puerto
#   específico en el sistema.
#
# USO:
#   xkill <puerto>
#
# EJEMPLO:
#   xkill 8080
#
# NOTA:
#   Si no se entrega el parámetro, muestra ayuda de uso.
# =========================================================

function xkill {

	# Si no recibe parámetros, muestra ayuda y sale
	if [ -z "$1" ]; then
		echo "======================================"
		echo "Uso: xkill <puerto>"
		echo "Ejemplo: xkill 8080"
		echo "======================================"
		return 1
	fi

	# Obtiene los PID asociados al puerto indicado
	pids=$(lsof -P | grep -i ":$1" | awk '{print $2}')

	# Si no hay procesos, informa y sale
	if [ -z "$pids" ]; then
		echo "No hay procesos usando el puerto $1"
		return 0
	fi

	# Muestra y termina los procesos encontrados
	echo "Matando procesos en puerto $1: $pids"
	echo "$pids" | xargs kill -9
}

