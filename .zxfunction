# ============================================================
# FUNCIÓN: xmvnglas
# Autor: Carlos Eduardo Ocando Azuaje
# Descripción:
# Compila proyecto Maven, elimina despliegue anterior en GlassFish
# y solicita gráficamente la ruta del archivo WAR para desplegarlo.
# ============================================================

function xmvnglas {

	# --------------------------------------------------------
	# Mostrar información inicial
	# --------------------------------------------------------
	echo -e "La compilación del proyecto iniciará ahora."
	echo -e "Debe seleccionar el archivo WAR completo para desplegar en GlassFish.\n"

	# --------------------------------------------------------
	# Solicitar ruta del WAR en modo gráfico (macOS)
	# --------------------------------------------------------
	WAR=$(osascript -e 'POSIX path of (choose file with prompt "Seleccione el archivo WAR para desplegar en GlassFish:")')

	WAR_PAT="$1"

	# --------------------------------------------------------
	# Validar selección
	# --------------------------------------------------------
	if [ -z "$WAR" ]; then
		echo "No se seleccionó ningún archivo WAR."
		return 1
	fi

	# --------------------------------------------------------
	# Compilar proyecto
	# --------------------------------------------------------
	echo "Compilando proyecto con Maven..."
	mvn clean package

	# --------------------------------------------------------
	# Eliminar despliegue anterior
	# --------------------------------------------------------

	echo "Eliminando despliegue anterior..."
	asadmin list-deployments | grep referidos2intento-1.0 || exit 0
	if [ $? -ne 0 ]; then
		echo "No se encontró despliegue previo. Continuando con deploy..."
		exit 0
	fi

	echo "Eliminando despliegue anterior..."
	asadmin --host localhost --port 4848 undeploy referidos2intento-1.0

	# --------------------------------------------------------
	# Abrir panel de GlassFish
	# --------------------------------------------------------
	open -n "http://localhost:4848/common/index.jsf"

	# --------------------------------------------------------
	# Pausa breve
	# --------------------------------------------------------
	sleep 2
	# return 0

	# --------------------------------------------------------
	# Desplegar nuevo WAR
	# --------------------------------------------------------
	echo "Desplegando nuevo archivo WAR..."
	asadmin deploy --force=true "$WAR_PAT""$WAR"

	# # --------------------------------------------------------
	# # Reabrir panel de administración
	# # --------------------------------------------------------
	open -n "http://localhost:4848/common/index.jsf"

	# --------------------------------------------------------
	# Confirmación final
	# --------------------------------------------------------
	echo
	echo "Proceso finalizado correctamente."
}

# ============================================================
# FUNCIÓN: XDRIVEUP
# Autor: Carlos Eduardo Ocando Azuaje
# Descripción:
#   - Realiza subida interactiva de archivos a Google Drive
#   - Utiliza rclone configurado con el remote "gdrive"
#   - Permite subir múltiples archivos uno por uno
#   - Valida existencia de archivos
#   - Solicita confirmación para continuar
#
# Requisitos:
#   - rclone instalado
#   - Remote configurado: gdrive
#   - Cuenta: cocandoazuaje@gmail.com
#
# Uso:
#   xdriveup
# ============================================================

function xdriveup() {

	# --------------------------------------------------------
	# Validar que no se reciban parámetros
	# --------------------------------------------------------
	if [[ $# -ne 0 ]]; then
		echo "=================================================="
		echo "USO:"
		echo "  xdriveup"
		echo ""
		echo "DESCRIPCIÓN:"
		echo "  Sube archivos a Google Drive uno por uno."
		echo "  Después de cada archivo pregunta si deseas subir otro."
		echo ""
		echo "CUENTA:"
		echo "  cocandoazuaje@gmail.com"
		echo ""
		echo "REMOTE:"
		echo "  gdrive"
		echo "=================================================="
		return 1
	fi

	# --------------------------------------------------------
	# Variables locales
	# --------------------------------------------------------
	local FILE_PATH
	local FILE_NAME
	local RESPUESTA

	# --------------------------------------------------------
	# Encabezado inicial
	# --------------------------------------------------------
	echo "=================================================="
	echo "SUBIDA INTERACTIVA A GOOGLE DRIVE"
	echo "Cuenta: cocandoazuaje@gmail.com"
	echo "Destino: gdrive:/"
	echo "=================================================="

	# --------------------------------------------------------
	# Bucle principal de subida
	# --------------------------------------------------------
	while true; do

		# ----------------------------------------------------
		# Solicitar ruta del archivo
		# ----------------------------------------------------
		echo ""
		read "FILE_PATH?Ruta completa del archivo a subir: "

		# ----------------------------------------------------
		# Validar existencia del archivo
		# ----------------------------------------------------
		if [[ ! -f "$FILE_PATH" ]]; then
			echo "❌ Error: Archivo no encontrado."
			continue
		fi

		# ----------------------------------------------------
		# Obtener nombre del archivo
		# ----------------------------------------------------
		FILE_NAME=$(basename "$FILE_PATH")

		# ----------------------------------------------------
		# Mostrar información de subida
		# ----------------------------------------------------
		echo "--------------------------------------------------"
		echo "Subiendo: $FILE_NAME"
		echo "--------------------------------------------------"

		# ----------------------------------------------------
		# Ejecutar subida con rclone
		# ----------------------------------------------------
		echo "Subiendo $FILE_NAME ..."
		rclone copy "$FILE_PATH" gdrive:/ \
			--exclude "**/node_modules/**" \
			--exclude "**/.git/**" \
			--exclude "**/target/**" \
			--exclude "**/dist/**" \
			--exclude ".Trash-*/**" \
			--exclude ".Trashes/**" \
			--exclude "Trash/**" \
			--exclude ".Trash/**"

		# ----------------------------------------------------
		# Validar resultado
		# ----------------------------------------------------
		if [[ $? -eq 0 ]]; then
			echo "✅ Archivo subido correctamente: $FILE_NAME"
		else
			echo "❌ Error durante subida."
		fi

		# ----------------------------------------------------
		# Preguntar si desea continuar
		# ----------------------------------------------------
		while true; do
			echo ""
			read "RESPUESTA?¿Deseas subir otro archivo? (s/n): "

			case "$RESPUESTA" in
			s | S)

				# Continuar bucle principal
				break
				;;

			n | N)

				# Finalizar proceso
				echo "=================================================="
				echo "Proceso finalizado."
				echo "=================================================="
				return 0
				;;

			*)

				# Respuesta inválida
				echo "⚠️ Respuesta inválida. Usa s o n."
				;;
			esac
		done
	done
}

# ============================================================
# FUNCIÓN: xtart
# DESCRIPCIÓN:
#   Lista el contenido interno de archivos TAR/TAR.GZ/TGZ
#   usando:
#     tar -tf
#
# USO:
#   xtart <archivo_tar>
#
# EJEMPLO:
#   xtart todo_git.tar.gz
# ============================================================

function xtart() {

	# Validar parámetro
	if [[ $# -lt 1 ]]; then
		echo "=================================================="
		echo "FUNCIÓN: xtart"
		echo "=================================================="
		echo "DESCRIPCIÓN:"
		echo "  Muestra el contenido interno de archivos comprimidos:"
		echo "   - .tar"
		echo "   - .tar.gz"
		echo "   - .tgz"
		echo "   - .tar.bz2"
		echo ""
		echo "COMANDO UTILIZADO:"
		echo "  tar -tf <archivo>"
		echo ""
		echo "USO:"
		echo "  xtart <archivo_tar>"
		echo ""
		echo "EJEMPLO:"
		echo "  xtart todo_git.tar.gz"
		echo "=================================================="
		return 1
	fi

	local TAR_FILE="$1"

	# Validar existencia
	if [[ ! -f "$TAR_FILE" ]]; then
		echo "❌ Error: Archivo no encontrado -> $TAR_FILE"
		return 1
	fi

	echo "=================================================="
	echo "LISTANDO CONTENIDO:"
	echo "  $TAR_FILE"
	echo "=================================================="

	tar -tf "$TAR_FILE" | grep -i "$2"

	if [[ $? -ne 0 ]]; then
		echo "❌ Error: No se pudo listar el contenido del archivo."
		return 1
	fi
}

# ============================================================
# FUNCIÓN: xgitz
# DESCRIPCIÓN:
#   Respalda y sube a Git archivos personales:
#     - ~/.zshrc
#     - ~/.zxalias
#     - ~/.zxfunction
#
# FUNCIONES:
#   ✔ Copia archivos al directorio actual
#   ✔ Git add
#   ✔ Git commit
#   ✔ Git push
#
# USO:
#   xgitz "mensaje commit"
#
# EJEMPLO:
#   xgitz "Backup configuración shell"
# ============================================================

function xgitz() {

	local COMMIT_MSG="Actualizando perfiles ..."
	local ZSHRC="$HOME/.zshrc"
	local ZXALIAS="$HOME/.zxalias"
	local ZXFUNCTION="$HOME/.zxfunction"

	# Validar existencia de archivos
	for FILE in "$ZSHRC" "$ZXALIAS" "$ZXFUNCTION"; do
		if [[ ! -f "$FILE" ]]; then
			echo "❌ Error: No existe $FILE"
			return 1
		fi
	done

	echo "=================================================="
	echo "COPIANDO ARCHIVOS DE CONFIGURACIÓN..."
	echo "=================================================="

	cp "$ZSHRC" .
	cp "$ZXALIAS" .
	cp "$ZXFUNCTION" .

	echo "=================================================="
	echo "SUBIENDO A GIT..."
	echo "=================================================="
	echo -e "\nMostrando status ...\n"
	git status \.zxalias \.zxfunction \.zshrc
	xread-e "siguiente paso...\n"
	echo -e "\nSubiendo ...\n"
	git add .zshrc .zxalias .zxfunction || return 1
	git commit -m "$COMMIT_MSG" || return 1
	git push || return 1
	echo -e "\nMostrando status ...\n"
	git status \.zxalias \.zxfunction \.zshrc

	echo -e "\n=================================================="
	echo "✅ Respaldo completado correctamente."
	echo -e "==================================================\n"
}

# ============================================================
# FUNCIÓN: XFINDPORC
# Autor: Carlos Eduardo Ocando Azuaje
# Descripción:
#   - Busca archivos desde el directorio HOME (~)
#   - Muestra progreso porcentual durante el recorrido
#   - Filtra resultados por expresión regular
#   - Muestra coincidencias con porcentaje de avance
#
# Uso:
#   xfindporc <patrón>
#
# Ejemplo:
#   xfindporc "crypto|encrypt|jar"
# ============================================================

function xfindporc() {

	# ----------------------------------------------------------
	# Validar parámetro obligatorio
	# ----------------------------------------------------------
	if [ $# -eq 0 ]; then
		echo "Uso: xfindporc <patrón>"
		echo ""
		echo "Ejemplo:"
		echo '  xfindporc "crypto|encrypt|jar"'
		return 1
	fi

	# ----------------------------------------------------------
	# Informar inicio
	# ----------------------------------------------------------
	echo "**** Calculando total de archivos..."

	# ----------------------------------------------------------
	# Calcular cantidad total de archivos
	# ----------------------------------------------------------
	total=$(find ~ -type f 2>/dev/null | wc -l | tr -d ' ')

	# ----------------------------------------------------------
	# Mostrar información general
	# ----------------------------------------------------------
	echo "Total archivos: $total"
	echo "**** Buscando: $1"
	echo "------------------------------"

	# ----------------------------------------------------------
	# Inicializar contador
	# ----------------------------------------------------------
	count=0

	# ----------------------------------------------------------
	# Recorrer archivos
	# ----------------------------------------------------------
	find ~ -type f 2>/dev/null | while read -r file; do

		# Incrementar contador
		count=$((count + 1))

		# Calcular porcentaje
		percent=$((count * 100 / total))

		# --------------------------------------------------------
		# Aplicar filtro
		# --------------------------------------------------------
		echo "$file" | grep -iE "$1" >/dev/null

		# --------------------------------------------------------
		# Mostrar coincidencias
		# --------------------------------------------------------
		if [ $? -eq 0 ]; then
			echo "[$percent%] $file"
		fi
	done
}

# ============================================================
# FUNCIÓN: xbateria
# DESCRIPCIÓN:
#   Muestra información detallada de la batería:
#   - Porcentaje restante
#   - Estado de carga (cargando, descargando, completa)
#   - Tiempo estimado (Linux con acpi)
#   - Nivel de salud (si está disponible)
#   Incluye colores para resaltar la información.
#
# USO:
#   xbateria
#
# EJEMPLO:
#   xbateria
# ============================================================
function xbate() {
	OS=$(uname)

	# Colores
	VERDE="\033[1;32m"
	AMARILLO="\033[1;33m"
	ROJO="\033[1;31m"
	AZUL="\033[1;34m"
	CYAN="\033[1;36m"
	RESET="\033[0m"

	echo -e "${CYAN}======================================${RESET}"
	echo -e "${CYAN}   Información de la batería${RESET}"
	echo -e "${CYAN}======================================${RESET}"

	if [[ "$OS" == "Darwin" ]]; then
		# macOS
		INFO=$(pmset -g batt)
		PORCENTAJE=$(echo "$INFO" | grep -Eo "[0-9]+%")
		ESTADO=$(echo "$INFO" | grep -Eo "charging|discharging|charged")
		TIEMPO=$(echo "$INFO" | grep -Eo "[0-9]+:[0-9]+")

		NUM=${PORCENTAJE%\%}
		if ((NUM > 70)); then
			COLOR=$VERDE
		elif ((NUM > 30)); then
			COLOR=$AMARILLO
		else
			COLOR=$ROJO
		fi

		echo -e "🔋 Porcentaje: ${COLOR}${PORCENTAJE}${RESET}"
		echo -e "⚡ Estado: ${AMARILLO}${ESTADO}${RESET}"
		[[ -n "$TIEMPO" ]] && echo -e "⏳ Tiempo restante: ${AZUL}${TIEMPO}${RESET}"

	elif [[ "$OS" == "Linux" ]]; then
		# Linux
		if command -v acpi >/dev/null 2>&1; then
			INFO=$(acpi -b)
			PORCENTAJE=$(echo "$INFO" | grep -Eo "[0-9]+%")
			ESTADO=$(echo "$INFO" | grep -Eo "Charging|Discharging|Full")
			TIEMPO=$(echo "$INFO" | grep -Eo "[0-9]+:[0-9]+:[0-9]+")
			SALUD=$(acpi -i | grep -i "capacity" | awk '{print $NF}')

			NUM=${PORCENTAJE%\%}
			if ((NUM > 70)); then
				COLOR=$VERDE
			elif ((NUM > 30)); then
				COLOR=$AMARILLO
			else
				COLOR=$ROJO
			fi

			echo -e "🔋 Porcentaje: ${COLOR}${PORCENTAJE}${RESET}"
			echo -e "⚡ Estado: ${AMARILLO}${ESTADO}${RESET}"
			[[ -n "$TIEMPO" ]] && echo -e "⏳ Tiempo restante: ${AZUL}${TIEMPO}${RESET}"
			[[ -n "$SALUD" ]] && echo -e "❤️ Salud de la batería: ${CYAN}${SALUD}${RESET}"
		else
			echo "❌ El comando 'acpi' no está instalado."
			echo "Instálalo con: sudo apt install acpi"
		fi
	else
		echo "⚠️ Sistema operativo no soportado: $OS"
	fi
}

# ============================================================
# FUNCIONES DE INFORMACIÓN DEL SISTEMA, RED Y UTILIDADES
# Autor: Carlos Eduardo Ocando Azuaje
# Descripción:
#   - xdf   : muestra uso de disco con colores
#   - xinfo : panel completo de información del sistema
#   - xtra  : traduce texto del portapapeles
#   - xping : realiza pruebas de conectividad sobre /etc/hosts
# ============================================================

# ____________________________________________________________
# DISCO
# VISUALIZACIÓN DE ESPACIO EN DISCO
# ____________________________________________________________
function xdf() {

	# Mostrar información de disco con encabezados coloreados
	df -h | awk '
	NR==1 {
		print "\033[1;36m" $0 "\033[0m"
	}
	NR==2 {
		print "\033[1;32m" $0 "\033[0m"
	}
	'
}

# ____________________________________________________________
# INFORMACIÓN GENERAL DEL SISTEMA
# PANEL DE ESTADO COMPLETO
# ____________________________________________________________
function xinfo() {

	# Limpiar pantalla
	clear

	# ----------------------------------------------------------
	# ENCABEZADO USUARIO
	# ----------------------------------------------------------
	echo -e "\033[1;36m==============================\033[0m"
	echo -e "\033[1;32m        INFO DEL Usuario      \033[0m"
	echo -e "\033[1;36m==============================\033[0m"

	echo -e "\033[1;33mUsuario:\033[0m $USER"
	echo -e "\033[1;33mEquipo:\033[0m $(scutil --get ComputerName 2>/dev/null)"
	echo -e "\033[1;33mHost:\033[0m $(hostname)"

	# ----------------------------------------------------------
	# DETECTAR VERSIÓN DE macOS
	# ----------------------------------------------------------
	version=$(sw_vers -productVersion)

	case "$version" in
	26*) name="Tahoe" ;;
	25*) name="Sequoia" ;;
	24*) name="Sonoma" ;;
	23*) name="Ventura" ;;
	22*) name="Monterey" ;;
	21*) name="Big Sur" ;;
	*) name="Desconocido" ;;
	esac

	# ----------------------------------------------------------
	# INFORMACIÓN DEL SISTEMA
	# ----------------------------------------------------------
	echo -e "\033[1;36m==============================\033[0m"
	echo -e "\033[1;32m    INFORMACION DEL SISTEMA   \033[0m"
	echo -e "\033[1;36m==============================\033[0m"

	echo -e "\033[1;33mSistema Operativo:\033[0m macOS \033[1;36m$name\033[0m"
	echo -e "\033[1;33mVersión:\033[0m $version"
	echo -e "\033[1;33mBuild:\033[0m $(sw_vers -buildVersion)"
	echo -e "\033[1;33mCPU:\033[0m $(sysctl -n machdep.cpu.brand_string)"

	# ----------------------------------------------------------
	# MEMORIA RAM
	# ----------------------------------------------------------
	ram=$(sysctl -n hw.memsize)
	ram_gb=$(awk "BEGIN {printf \"%.2f\", $ram/1024/1024/1024}")

	echo -e "\033[1;33mRAM:\033[0m ${ram_gb} GB"

	# ----------------------------------------------------------
	# TIEMPO ENCENDIDO
	# ----------------------------------------------------------
	echo -e "\033[1;33mUptime:\033[0m $(uptime | awk -F'up ' '{print $2}' | awk -F',' '{print $1}')"

	# ----------------------------------------------------------
	# DISCO
	# ----------------------------------------------------------
	echo -e "\033[1;36m==============================\033[0m"
	echo -e "\033[1;32m     INFORMACION DEL DISCO    \033[0m"
	echo -e "\033[1;36m==============================\033[0m"

	df -h / | awk '
	NR==1 {
		print "\033[1;36m" $0 "\033[0m"
	}
	NR==2 {
		use=$5
		gsub("%","",use)

		color = (use >= 80) ? "\033[1;31m" : "\033[1;32m"
		print-e f "%s%s\033[0m\n", color, $0
	}
	'

	# ----------------------------------------------------------
	# BATERÍA
	# ----------------------------------------------------------
	echo -e "\033[1;36m==============================\033[0m"
	echo -e "\033[1;32m      ESTADO DE LA BATERÍA    \033[0m"
	echo -e "\033[1;36m==============================\033[0m"

	system_profiler SPPowerDataType | awk '
	/Cycle Count/ {
		cycles = $3

		if (cycles < 300)
			color="\033[1;32m"
		else if (cycles < 800)
			color="\033[1;33m"
		else
			color="\033[1;31m"

			print-e f "%sCiclos: %s\033[0m\n", color, cycles
		}

		/Condition/ {
			print "Condición:", $2
		}

		/Full Charge Capacity/ {
			print "Capacidad máxima:", $4, $5
		}

		/State of Charge/ {
			print "Carga actual:", $4, $5
		}

		/Charging/ {
			print "Cargando:", $2
		}
		'

	echo "----------------------------"

	battery=$(pmset -g batt | grep -o "[0-9]\+%")
	echo -e "\033[1;33mPorcentaje actual:\033[0m $battery"
}

# ____________________________________________________________
# TRADUCCIÓN
# TRADUCE TEXTO DEL PORTAPAPELES
# ____________________________________________________________
function xtraduc {

	# ----------------------------------------------------------
	# VALIDAR DEPENDENCIA
	# ----------------------------------------------------------
	if ! command -v trans &>/dev/null; then
		echo "❌ Error: translate-shell (trans) no está instalado."
		echo "📦 Instálalo con: brew install translate-shell"
		exit 1
	fi

	# ----------------------------------------------------------
	# OBTENER TEXTO
	# ----------------------------------------------------------
	texto=$(pbpaste)

	# ----------------------------------------------------------
	# VALIDAR CONTENIDO
	# ----------------------------------------------------------
	if [ -z "$texto" ]; then
		echo "⚠️ El portapapeles está vacío."
		exit 1
	fi

	# ----------------------------------------------------------
	# TRADUCCIÓN
	# ----------------------------------------------------------
	echo "🔄 Traduciendo del inglés al español..."
	traduccion=$(trans -brief -source en -target es "$texto")

	# ----------------------------------------------------------
	# MOSTRAR RESULTADO
	# ----------------------------------------------------------
	echo "✅ Traducción:"
	echo "$traduccion"

	# ----------------------------------------------------------
	# LECTURA EN VOZ ALTA
	# ----------------------------------------------------------
	say -v Monica "$traduccion"
}

# ____________________________________________________________
# PING
# VERIFICACIÓN DE HOSTS DEFINIDOS EN /etc/hosts
# ____________________________________________________________
function xping() {

	# ----------------------------------------------------------
	# COLORES
	# ----------------------------------------------------------
	GREEN="\033[1;32m"
	BLUE="\033[1;34m"
	YELLOW="\033[1;33m"
	RED="\033[1;31m"
	RESET="\033[0m"

	# ----------------------------------------------------------
	# INICIO
	# ----------------------------------------------------------
	echo -e "${BLUE}=== Iniciando ping de /etc/hosts ===${RESET}"

	# ----------------------------------------------------------
	# RECORRER HOSTS
	# ----------------------------------------------------------
	while read -r ip host _; do

		# Ignorar comentarios y líneas vacías
		[[ -z "$ip" || "$ip" == \#* ]] && continue

		# Validar IPv4
		if [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]; then

			echo ""
			echo -e "${YELLOW}>>> Ping a ${GREEN}$ip${RESET} (${host})"

			# Ejecutar ping
			ping -c 3 "$ip" >/dev/null 2>&1

			# Mostrar resultado
			if [ $? -eq 0 ]; then
				echo -e "${GREEN}✔ $ip responde${RESET}"
			else
				echo -e "${RED}✖ $ip no responde${RESET}"
			fi
		fi

	done </etc/hosts

	# ----------------------------------------------------------
	# FIN
	# ----------------------------------------------------------
	echo -e "${BLUE}=== Finalizado ===${RESET}"
}

function xsyngit() {

	echo "=============================="
	echo "  INICIANDO SINCRONIZACIÓN"
	echo "=============================="

	# # ------------------------------------------------------------
	# # Validar parámetro obligatorio
	# # ------------------------------------------------------------
	# if [[ -z "$1" ]]; then
	# 	echo "⚠️  No se recibió mensaje de commit"
	# 	echo "💡 Uso: xsyngit \"mensaje del commit\""
	# 	return 1
	# fi

	# MENSAJE="$1"

	# Definir colores ANSI para darle un toque zen
	MENSAJE=$(zenity --entry --title="Entrada" --text="Escriba el mensaje:") 2>/dev/null

	# Validar entrada
	if [[ -z "$MENSAJE" ]]; then
		echo "**** Operación cancelada."
		exit 1
	fi

	# rclone copy -L "$MENSAJE" "$REMOTO:$CARPETA_REMOTA" --progress
	rclone copy "$HOME" "$REMOTO:$CARPETA_REMOTA" \
		--progress \
		--exclude "**/node_modules/**" \
		--exclude "**/.git/**" \
		--exclude "**/target/**" \
		--exclude "**/dist/**" \
		--exclude ".Trash-*/**" \
		--exclude ".Trashes/**" \
		--exclude "Trash/**" \
		--exclude ".Trash/**"

	# Sync de configuración
	# ------------------------------------------------------------
	rsync -avh --progress ~/.zxalias /Users/carlosocando/para_git/
	rsync -avh --progress ~/.zxfunction /Users/carlosocando/para_git/
	rsync -avh --progress ~/.zshrc /Users/carlosocando/para_git/

	# ------------------------------------------------------------
	# Cargar dependencias externas
	# ------------------------------------------------------------
	# if [[ -f "/Users/carlosocando/para_git/trae_zx.sh" ]]; then
	#   source /Users/carlosocando/para_git/trae_zx.sh
	# else
	#   echo "❌ Error: no se encontró trae_zx.sh"
	#   return 1
	# fi

	# ------------------------------------------------------------
	# Variables principales
	# ------------------------------------------------------------
	ORIGEN="/Users/carlosocando/Documentos/ionix/Desarrollando/"
	DESTINO="$HOME/para_git/"

	# ------------------------------------------------------------
	# Validar directorio origen
	# ------------------------------------------------------------
	if [[ ! -d "$ORIGEN" ]]; then
		echo "❌ Error: el directorio origen no existe: $ORIGEN"
		return 1
	fi

	# ------------------------------------------------------------
	# Sincronización principal
	# ------------------------------------------------------------
	echo "📦 Sincronizando archivos..."
	rsync -avh --progress "$ORIGEN"* "$DESTINO"

	if [[ $? -ne 0 ]]; then
		echo "❌ Error durante rsync"
		exit 1
	fi

	# ------------------------------------------------------------
	# Commit automático
	# ------------------------------------------------------------
	echo "🧾 Ejecutando commit..."
	xgitall "$MENSAJE"

	tar -czvf para_git.targz *
	ll *tar.gz

	xread "?Presione ENTER para continuar ..."

	xgitall

	echo "=============================="
	echo "  SINCRONIZACIÓN COMPLETADA"
	echo "=============================="
}

# ============================================================
# FUNCIÓN: xclose
# AUTOR: Carlos Ocando
# DESCRIPCIÓN:
#   Cierra aplicaciones en macOS de forma limpia (equivalente
#   a Cmd + Q) usando AppleScript.
#
#   - Recibe como parámetro el nombre de la aplicación
#   - Si no recibe parámetro, muestra ayuda de uso
#   - Espera a que la aplicación se cierre completamente
#
# USO:
#   xclose "Brave Browser"
#   xclose "Safari"
#   xclose "Google Chrome"
# ============================================================

function xclose {

	echo "================================================"
	echo "        CERRADOR DE APLICACIONES macOS"
	echo "================================================"

	# ------------------------------------------------------------
	# VALIDACIÓN DE PARÁMETRO
	# ------------------------------------------------------------
	if [[ -z "$1" ]]; then
		echo ""
		echo "❌ ERROR: No se recibió el nombre de la aplicación"
		echo ""
		echo "🧠 USO CORRECTO:"
		echo "   xclose \"Brave Browser\""
		echo "   xclose \"Safari\""
		echo "   xclose \"Google Chrome\""
		echo ""
		echo "💡 Este comando cierra la aplicación de forma limpia"
		echo "   (equivalente a Cmd + Q)"
		echo ""
		return 1
	fi

	# ------------------------------------------------------------
	# VARIABLE PRINCIPAL
	# ------------------------------------------------------------
	APP_NAME="$1"

	echo ""
	echo "🧾 Cerrando aplicación: $APP_NAME"
	echo ""

	# ------------------------------------------------------------
	# CIERRE LIMPIO (APPLE SCRIPT)
	# ------------------------------------------------------------
	osascript -e "tell application \"$APP_NAME\" to quit"

	# ------------------------------------------------------------
	# ESPERAR CIERRE COMPLETO DEL PROCESO
	# ------------------------------------------------------------
	while pgrep -f "$APP_NAME" >/dev/null; do
		sleep 0.5
	done

	echo ""
	echo "✅ $APP_NAME cerrado correctamente"
	echo "================================================"
}

# ============================================================
# FUNCIÓN: xformat
# Autor: Carlos Eduardo Ocando Azuaje
# Descripción:
#   - Formatea scripts Bash/Zsh usando shfmt
#   - Reindenta automáticamente
#   - Sobrescribe el archivo original
#   - Muestra estado del proceso
#
# Uso:
#   xformat <archivo>
#
# Ejemplo:
#   xformat ~/.zxfunction
# ============================================================

function xformat {

	# ----------------------------------------------------------
	# Validar parámetro obligatorio
	# ----------------------------------------------------------
	if [[ -z "$1" ]]; then
		echo "=================================================="
		echo "FUNCIÓN: xformat"
		echo "=================================================="
		echo "DESCRIPCIÓN:"
		echo "  Formatea scripts Bash/Zsh usando shfmt."
		echo ""
		echo "FUNCIONES:"
		echo "  ✔ Reindentación automática"
		echo "  ✔ Corrección estructural"
		echo "  ✔ Sobrescribe archivo original"
		echo ""
		echo "REQUISITO:"
		echo "  brew install shfmt"
		echo ""
		echo "USO:"
		echo "  xformat <archivo>"
		echo ""
		echo "EJEMPLO:"
		echo "  xformat ~/.zxfunction"
		echo "=================================================="
		return 1
	fi

	# ----------------------------------------------------------
	# Validar existencia del archivo
	# ----------------------------------------------------------
	if [[ ! -f "$1" ]]; then
		echo "❌ Error: Archivo no encontrado -> $1"
		return 1
	fi

	# ----------------------------------------------------------
	# Validar dependencia
	# ----------------------------------------------------------
	if ! command -v shfmt >/dev/null 2>&1; then
		echo "❌ Error: shfmt no está instalado."
		echo "📦 Instálalo con: brew install shfmt"
		return 1
	fi

	# ----------------------------------------------------------
	# Inicio
	# ----------------------------------------------------------
	echo "=================================================="
	echo "🔧 Formateando: $1"
	echo "=================================================="

	# ----------------------------------------------------------
	# Ejecutar formateo
	# ----------------------------------------------------------
	shfmt -i 0 -w "$1"

	# ----------------------------------------------------------
	# Validar resultado
	# ----------------------------------------------------------
	if [[ $? -eq 0 ]]; then
		echo ""
		echo "✅ Proceso finalizado correctamente."
	else
		echo ""
		echo "❌ Error durante el formateo."
		return 1
	fi

}

function xformatall() {

	if [ "$1" = "?" ]; then
		echo "--------------------------------------------------"
		echo "FUNCION: xsformatall"
		echo "--------------------------------------------------"
		echo "Descripción:"
		echo "  Formatea todos los archivos JavaScript del proyecto"
		echo "  usando Prettier."
		echo ""
		echo "Comando ejecutado:"
		echo "  npx prettier --write \"**/*.js\""
		echo ""
		echo "Uso:"
		echo "  xsformatall      -> ejecuta formateo"
		echo "  xsformatall ?    -> muestra esta ayuda"
		echo "--------------------------------------------------"
		return 0
	fi

	echo "Formateando archivos JS..."
	npx prettier --write "**/*.js"

}

# ============================================================
# FUNCIÓN: xsintax
# Autor: Carlos Eduardo Ocando Azuaje
# Descripción:
# Verifica la sintaxis de un archivo o script Bash sin ejecutarlo.
# Útil para detectar errores estructurales antes de usar o ejecutar scripts.
# ============================================================

function xsintax {

	# --------------------------------------------------------
	# Validar que se haya proporcionado un archivo
	# --------------------------------------------------------
	if [ $# -eq 0 ]; then
		echo "========================================="
		echo "         VALIDADOR DE SINTAXIS BASH      "
		echo "========================================="
		echo
		echo "Uso:"
		echo "xsintax <archivo>"
		echo
		echo "Descripción:"
		echo "Verifica errores de sintaxis en scripts Bash"
		echo "sin ejecutar el contenido."
		echo
		echo "Ejemplo:"
		echo "xsintax ~/.zxfunction"
		echo
		echo "========================================="
		return 1
	fi

	# --------------------------------------------------------
	# Verificar sintaxis del archivo
	# --------------------------------------------------------
	echo "========================================="
	echo "Verificando sintaxis de: $1"
	echo "========================================="

	bash -n "$1"

	# --------------------------------------------------------
	# Evaluar resultado
	# --------------------------------------------------------
	if [ $? -eq 0 ]; then
		echo
		echo "Sintaxis correcta."
	else
		echo
		echo "Se detectaron errores de sintaxis."
	fi
}

# ============================================================
# FUNCIÓN: xverfunc
# Autor: Carlos Eduardo Ocando Azuaje
# Descripción:
# Muestra en pantalla el contenido completo de una función
# específica almacenada dentro del archivo ~/.zxfunction.
#
# Uso:
#   xverfunc nombre_funcion
#
# Ejemplo:
#   xverfunc xgitall
#
# Si no recibe parámetro:
#   Explica su funcionamiento.
# ============================================================

function xverfunc {

	# --------------------------------------------------------
	# VALIDAR PARÁMETRO
	# --------------------------------------------------------
	if [ -z "$1" ]; then
		echo -e "\033[1;36m=========================================\033[0m"
		echo -e "\033[1;32m         VISOR DE FUNCIONES BASH         \033[0m"
		echo -e "\033[1;36m=========================================\033[0m"
		echo
		echo "Uso: xverfunc nombre_funcion"
		echo
		echo "Descripción:"
		echo "Busca y muestra el código completo de una función"
		echo "dentro del archivo:"
		echo "  $HOME/.zxfunction"
		echo
		echo "Ejemplo:"
		echo "  xverfunc xgitall"
		echo
		return 1
	fi

	cat "~/.zxfunction" | grep "$1"

	# --------------------------------------------------------
	# BUSCAR Y MOSTRAR FUNCIÓN
	# --------------------------------------------------------
	awk "/^function $1/,/^}/" "$HOME/.zxfunction"

}

# ============================================================
# FUNCIÓN: xveralias
# Autor: Carlos Eduardo Ocando Azuaje
# Descripción:
# Busca y muestra alias específicos dentro del archivo ~/.zxalias.
#
# Uso:
#   xveralias nombre_alias
#
# Ejemplo:
#   xveralias xformat
#
# Si no recibe parámetro:
#   Explica su funcionamiento.
# ============================================================

function xveralias {

	# --------------------------------------------------------
	# VALIDAR PARÁMETRO
	# --------------------------------------------------------
	if [ -z "$1" ]; then
		echo -e "\033[1;36m=========================================\033[0m"
		echo -e "\033[1;32m          VISOR DE ALIAS BASH            \033[0m"
		echo -e "\033[1;36m=========================================\033[0m"
		echo
		echo "Uso: xveralias nombre_alias"
		echo
		echo "Descripción:"
		echo "Busca y muestra coincidencias de alias"
		echo "dentro del archivo:"
		echo "  $HOME/.zxalias"
		echo
		echo "Ejemplo:"
		echo "  xveralias xformat"
		echo
		return 1
	fi

	# --------------------------------------------------------
	# BUSCAR ALIAS
	# --------------------------------------------------------
	grep "$1" "$HOME/.zxalias"

}

# ============================================================
# FUNCIÓN: xgittodo
# Autor: Carlos Eduardo Ocando Azuaje
# Descripción:
# Automatiza el proceso completo de Git:
#   1. Muestra estado del repositorio
#   2. Agrega todos los cambios
#   3. Realiza commit con mensaje personalizado
#   4. Hace push al repositorio remoto
#
# Uso:
#   xgittodo "mensaje del commit"
#
# Ejemplo:
#   xgittodo "Actualización de funciones"
#
# Si no recibe parámetro:
#   Explica su funcionamiento.
# ============================================================

function xgittodo {

	# --------------------------------------------------------
	# VALIDAR PARÁMETRO
	# --------------------------------------------------------
	if [ -z "$1" ]; then
		echo -e "\033[1;36m=========================================\033[0m"
		echo -e "\033[1;32m          AUTOMATIZADOR GIT              \033[0m"
		echo -e "\033[1;36m=========================================\033[0m"
		echo
		echo "Uso: xgittodo \"mensaje del commit\""
		echo
		echo "Descripción:"
		echo "Ejecuta automáticamente:"
		echo "  gits"
		echo "  git add ."
		echo "  git commit -m \"mensaje\""
		echo "  git push"
		echo
		echo "Ejemplo:"
		echo "  xgittodo \"Actualizando proyecto\""
		echo
		return 1
	fi

	# --------------------------------------------------------
	# PROCESO GIT COMPLETO
	# --------------------------------------------------------
	echo -e "\033[1;33mMostrando estado del repositorio...\033[0m"
	gits

	echo -e "\033[1;33mAgregando archivos...\033[0m"
	git add .

	echo -e "\033[1;33mRealizando commit...\033[0m"
	git commit -m "$1"

	echo -e "\033[1;33mEnviando cambios al remoto...\033[0m"
	git push

	echo
	echo -e "\033[1;32mProceso Git finalizado correctamente.\033[0m"

}

# ============================================================
# FUNCIÓN: xdiffllinea
# Autor: Carlos Eduardo Ocando Azuaje
# Descripción:
# Permite seleccionar gráficamente dos archivos mediante Finder
# y compara sus diferencias línea por línea.
#
# Uso:
#   xdiffllinea
#
# Si cancela selección:
#   Muestra error y finaliza.
# ============================================================

function xdifflinea {

	# --------------------------------------------------------
	# SELECCIONAR PRIMER ARCHIVO
	# --------------------------------------------------------
	ARCHIVO1=$(osascript -e 'POSIX path of (choose file with prompt "Seleccione el PRIMER archivo a comparar:")' 2>/dev/null)

	if [ -z "$ARCHIVO1" ]; then
		echo "Operación cancelada."
		return 1
	fi

	# --------------------------------------------------------
	# SELECCIONAR SEGUNDO ARCHIVO
	# --------------------------------------------------------
	ARCHIVO2=$(osascript -e 'POSIX path of (choose file with prompt "Seleccione el SEGUNDO archivo a comparar:")' 2>/dev/null)

	if [ -z "$ARCHIVO2" ]; then
		echo "Operación cancelada."
		return 1
	fi

	# --------------------------------------------------------
	# VALIDAR EXISTENCIA
	# --------------------------------------------------------
	if [ ! -f "$ARCHIVO1" ] || [ ! -f "$ARCHIVO2" ]; then
		echo "Error: Uno o ambos archivos no existen."
		return 1
	fi

	# --------------------------------------------------------
	# ENCABEZADO
	# --------------------------------------------------------
	echo -e "\033[1;36m=========================================\033[0m"
	echo -e "\033[1;32m      COMPARADOR LÍNEA POR LÍNEA         \033[0m"
	echo -e "\033[1;36m=========================================\033[0m"
	echo
	echo "Archivo 1: $ARCHIVO1"
	echo "Archivo 2: $ARCHIVO2"
	echo

	# --------------------------------------------------------
	# COMPARAR DIFERENCIAS
	# --------------------------------------------------------
	echo -e "\033[1;33mBuscando diferencias...\033[0m"
	diff -u "$ARCHIVO1" "$ARCHIVO2"

	echo
	echo -e "\033[1;32mComparación finalizada.\033[0m"

}

# ============================================================
# FUNCIÓN: xexiste
# Autor: Carlos Eduardo Ocando Azuaje
# Descripción:
# Verifica si un archivo existe en la ruta indicada.
#
# Uso:
#   xexiste archivo
#
# Ejemplo:
#   xexiste ~/.zshrc
#
# Si no recibe parámetro:
#   Muestra ayuda de uso.
# ============================================================

function xexiste {

	# --------------------------------------------------------
	# VALIDAR PARÁMETRO
	# --------------------------------------------------------
	if [ -z "$1" ]; then
		echo -e "\033[1;36m=========================================\033[0m"
		echo -e "\033[1;32m         VERIFICADOR DE ARCHIVOS         \033[0m"
		echo -e "\033[1;36m=========================================\033[0m"
		echo
		echo "Uso: xexiste archivo"
		echo
		echo "Descripción:"
		echo "Verifica si el archivo existe en la ruta indicada."
		echo
		echo "Ejemplo:"
		echo "  xexiste ~/.zshrc"
		echo
		return 1
	fi

	# --------------------------------------------------------
	# VERIFICACIÓN
	# --------------------------------------------------------
	echo -e "Verificando ..."
	test -f "$1" && echo "**** OK existe" || echo "---- NO existe"

}

# ============================================================
# FUNCIÓN: xfilefinder
# Autor: Carlos Eduardo Ocando Azuaje
# Descripción:
# Abre un selector gráfico (Finder en macOS) para elegir un
# archivo y devuelve su ruta en la variable RUTA.
#
# Uso:
#   xfilefinder "descripcion opcional"
#
# Ejemplo:
#   xfilefinder "archivo de configuración"
#
# Si no recibe parámetro:
#   Muestra ayuda de uso.
# ============================================================

function xfilefinder {

	# Si no recibe parámetro, mostrar ayuda
	if [[ $# -eq 0 ]]; then
		echo ""
		echo "USO:"
		echo "  xfilefinder \"descripcion\""
		echo ""
		echo "EJEMPLO:"
		echo "  xfilefinder \"archivo de configuración\""
		echo ""
		echo "DESCRIPCIÓN:"
		echo "  Abre Finder para seleccionar un archivo"
		echo "  y retorna la ruta en la variable RUTA."
		echo "============================================================"
		return 1
	fi

	RUTA=$(
		osascript <<'EOF'
try
POSIX path of (choose file with prompt "Seleccione un archivo")
on error
return ""
end try
EOF
	) 2>/dev/null

	if [[ -z "$RUTA" ]]; then
		xinfozen "**** Operación cancelada"
		return 1
	fi

	xinfozen "Para obtener la variabler simplemene usela ..RUTA"
}

function xinfozen {
	zenity --info --title="$1" --text="Proceso completado correctamente" 2>/dev/null

}

function xmvnclp() {

	local TITULO="${1:-Maven Build}"
	local PROYECTO
	local OUTPUT

	OUTPUT=$(asadmin list-applications 2>/dev/null)

	if echo "$OUTPUT" | grep -qi "nothing"; then
		echo "**** No hay aplicaciones desplegadas para eliminar."
	else
		WAR=$(echo "$OUTPUT" | awk 'NR==1 {print $1}')
		echo "**** Eliminando aplicación: $WAR"
		asadmin undeploy "$WAR"
	fi

	echo "**** Application encontrado -> $OUTPUT"
	xread 5

	PROYECTO=$(osascript -e 'POSIX path of (choose folder with prompt "Seleccione una carpeta")')

	# Cancelado o vacío
	if [[ -z "$PROYECTO" ]]; then
		zenity --info \
			--title="$PROYECTO" \
			--text="Operación cancelada" \
			2>/dev/null
		return 1
	fi
	# Validar carpeta
	if [[ ! -d "$PROYECTO" ]]; then
		zenity --error \
			--title="$TITULO" \
			--text="La ruta no existe:\n$PROYECTO" \
			2>/dev/null
		return 1
	fi

	# Validar pom.xml
	if [[ ! -f "$PROYECTO/pom.xml" ]]; then
		zenity --error \
			--title="$TITULO" \
			--text="No se encontró pom.xml en:\n$PROYECTO" \
			2>/dev/null
		return 1
	fi

	cd "$PROYECTO" || return 1

	echo "\n**** Haciendo deploy ..."$WAR_PATH"/"$WAR"."$EXTENCION_WAR" ...\n"
	xread "? **** Verificando"
	mvn clean package -X || return 1
	asadmind deploy "$1"/"$WAR.$EXTENCION_WAR"
	mv target/*.war . 2>/dev/null
	open /Users/carlosocando/Documentos/prueba2/p2_original_1_boton_referidos2intento--master
	xpausa 2
	open "http://localhost:4848/common/appServer/serverInstGeneralPe.jsf?instanceName=server"
	echo "**** Fin"

	zenity --info \
		--title="$TITULO" \
		--text="Proceso completado correctamente" \
		2>/dev/null
}

function xmvnall {
	echo "========================================"
	echo "**** Procesando ..."
	echo "========================================"

	xun xmvnlcp
	clear
	x
	xmvnclp

	echo "========================================"
	echo " **** Proceso finalizado correctamente"
	echo "========================================"
}

function xzen {

	local TIPO="$1"
	local MENSAJE="$2"

	if [ -z "$TIPO" ] || [ -z "$MENSAJE" ]; then
		echo "Uso:"
		echo '  xzen info "Mensaje"'
		echo '  xzen warning "Mensaje"'
		echo '  xzen error "Mensaje"'
		echo '  xzen entry "Mensaje"'
		echo '  xzen question "Mensaje"'
		return 1
	fi

	case "$TIPO" in
	info)
		zenity --info --title="Información" --text="$MENSAJE" 2>/dev/null
		;;
	warning) ;;
	error)
		zenity --error --title="Error" --text="$MENSAJE" 2>/dev/null
		;;
	entry)
		xval=$(zenity --entry --title="Entrada" --text="$MENSAJE" s) 2>/dev/null
		echo "$xval"
		echo $xval | xporta
		;;
	question)
		zenity --question --title="Confirmación" --text="$MENSAJE" 2>/dev/null
		;;
	*)
		echo "Tipo inválido: $TIPO"
		return 1
		;;
	esac
}
